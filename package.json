{
  "name": "webcomctl-js",
  "version": "0.0.5",
  "description": "Common controls library for the Web",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./document/*": "./src/document/*/index.mjs",
    "./document/*/template": "./src/document/*/template.mjs",
    "./control/*": "./src/control/*/index.mjs",
    "./control/*/template": "./src/control/*/template.mjs",
    "./loader/cmake-loader": "./src/loader/CMakeLoader.mjs",
    "./loader/module-loader": "./src/loader/ModuleLoader.mjs",
    "./loader/uic-static-loader": "./src/loader/UICStaticLoader.mjs",
    "./loader/uictmplt-loader": "./src/loader/UICTemplateLoader.mjs",
    "./loader/template-loader": "./src/loader/TemplateLoader.mjs",
    "./builders.config.mjs": "./builders.config.mjs",
    "./templates.config.mjs": "./templates.config.mjs",
    "./controls.config.mjs": "./controls.config.mjs"
  },
  "scripts": {
    "build-builders-debug": "webpack --config builders.config.mjs --mode=development --output-path=dist",
    "build-builders-release": "webpack --config builders.config.mjs --mode=production --output-path=dist",
    "build-templates-debug": "webpack --config templates.config.mjs --mode=development --output-path=dist",
    "build-templates-release": "webpack --config templates.config.mjs --mode=production --output-path=dist",
    "build-controls-debug": "webpack --config controls.config.mjs --mode=development --output-path=dist",
    "build-controls-release": "webpack --config controls.config.mjs --mode=production --output-path=dist",
    "build:debug": "npm run build-builders-debug && npm run build-templates-debug && npm run build-controls-debug",
    "build:release":  "npm run build-builders-release && npm run build-templates-release && npm run build-controls-release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ykbin/webcomctl-js.git"
  },
  "keywords": [
    "web", "node"
  ],
  "author": "Yurii Yakubin",
  "bugs": {
    "url": "https://github.com/ykbin/webcomctl-js/issues"
  },
  "homepage": "https://github.com/ykbin/webcomctl-js#readme",
  "dependencies": {
    "webnetq-js": "github:ykbin/webnetq-js",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "svgo": "^3.3.2"
  },
  "devDependencies": {
  }
}
